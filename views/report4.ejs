<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>PUMPSENSE | Certificate - <%= report.trueData.pumpDetails.model %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary: #003366;
      --secondary: #000000;
      --accent: #005b96;
      --light-blue: #eef3fb;
      --border: #b0b8c1;
      --bg: #f4f7f9;
      --text: #1a1a1a;
      --highlight: #d1e3f3;
      --tolerance-bg: #f0f4f8; 
    }

    body {
      font-family: "Segoe UI", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .fade-in { animation: fadeIn 0.3s ease-out forwards; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* Dropdown transition */
    .dropdown-menu {
        display: none;
        opacity: 0;
        transform: translateY(-10px);
        transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .dropdown-menu.show {
        display: block;
        opacity: 1;
        transform: translateY(0);
    }

    /* Report Content Styling */
    .page-content {
      background: #fff;
      padding: 20px;
      border: 1px solid #ccc;
      box-shadow: 0 0 15px rgba(0,0,0,0.05);
    }

    .header-table { width: 100%; border-collapse: collapse; margin-bottom: 5px; }
    .header-table td { border: 1px solid var(--border); padding: 8px; vertical-align: middle; }
    .logo-cell { width: 100px; text-align: center; }
    .meta-cell { width: 30%; font-size: 10px; }
    
    .circular-logo { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto; }
    .company-name { font-size: 16px; font-weight: bold; color: var(--primary); text-transform: uppercase; }
    .cert-title { font-size: 13px; font-weight: bold; text-decoration: underline; margin-top: 5px; display: block; }

    .grid-container { 
      display: grid; 
      grid-template-columns: repeat(4, 1fr); 
      border: 1px solid var(--border); 
      margin-bottom: 5px; 
    }
    .grid-item { border: 0.5px solid #eee; padding: 6px; display: flex; justify-content: space-between; align-items: center; gap: 5px; }
    .label { color: #555; font-weight: 500; font-size: 10px; }
    .value { font-weight: bold; font-size: 10px; text-align: right; }

    .refs-section { 
      display: grid; 
      grid-template-columns: repeat(3, 1fr); 
      border: 1px solid var(--border); 
      margin-bottom: 8px; 
      background: #fafafa; 
    }
    .ref-col { border-right: 1px solid var(--border); }
    .ref-col:last-child { border-right: none; }
    .ref-row { display: flex; justify-content: space-between; padding: 5px 8px; border-bottom: 0.5px solid #ddd; font-size: 10px; }

    .table-title { background: var(--primary); color: white; font-weight: bold; text-align: center; padding: 6px; text-transform: uppercase; font-size: 11px; }
    .table-wrapper { width: 100%; overflow-x: auto; margin-bottom: 8px; border: 1px solid var(--border); }
    table.data-table { width: 100%; border-collapse: collapse; min-width: 700px; }
    table.data-table th, table.data-table td { border: 1px solid var(--border); padding: 6px 4px; text-align: center; font-size: 10px; }
    table.data-table th { background: var(--light-blue); color: var(--primary); font-weight: bold; }
    .duty-point-row { background-color: var(--highlight) !important; font-weight: bold; }

    .side-flex { display: flex; border: 1px solid var(--border); margin-bottom: 10px; flex-wrap: wrap; }
    .side-left { flex: 2; border-right: 1px solid var(--border); min-width: 300px; }
    .side-right { flex: 1.2; min-width: 250px; }

    .mech-container { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 5px; }
    .mech-card { border: 1px solid var(--border); overflow-x: auto; }
    .mech-table { width: 100%; border-collapse: collapse; min-width: 280px; }
    .mech-table td, .mech-table th { border: 1px solid #ddd; padding: 5px 8px; font-size: 10px; }
    .mech-header { background: var(--light-blue); color: var(--primary); font-weight: bold; text-align: center; }
    .mech-row-header { background: #f4f4f4; font-weight: bold; width: 40%; }

    .tolerance-section { background: var(--tolerance-bg); border: 1px solid var(--border); margin: 10px 0; overflow-x: auto; }
    .tolerance-header { background: var(--primary); color: white; text-align: center; font-weight: bold; padding: 6px; font-size: 11px; }
    .tolerance-table { width: 100%; border-collapse: collapse; min-width: 500px; }
    .tolerance-table td { border: 1px solid var(--border); padding: 8px; font-size: 10px; }
    .tolerance-label { font-weight: bold; color: var(--primary); background: #fdfdfd; width: 25%; }

    .footer-signs { margin-top: 15px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 15px; }
    .sign-box { border: 1px solid var(--border); padding: 15px; flex: 1; min-width: 200px; text-align: center; }
    .sign-line { border-top: 1px solid #000; margin-top: 40px; padding-top: 5px; font-size: 10px; font-weight: bold; }

    .modal { display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); overflow-y: auto; }
    .modal-content { background: #fff; margin: 2% auto; padding: 15px; width: 95%; max-width: 1200px; border-radius: 8px; }
    .chart-box { border: 1px solid var(--border); height: 350px; margin-bottom: 20px; padding: 10px; background: white; }

    /* Fix: Print logic area should not be display:none during initialization */
    #print-graphs-area { 
        position: absolute;
        left: -9999px;
        top: 0;
        width: 1050px; /* Standard A4 width approximation */
        background: white;
    }

    @media print {
      .header-nav, .action-bar, #toggleDataBtn { display: none !important; }
      body { background: white; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .page-content { border: none; box-shadow: none; margin: 0; padding: 0; width: 100%; }
      #print-graphs-area { 
          position: static; 
          display: block !important; 
          left: 0; 
          page-break-before: always; 
      }
      .chart-box { page-break-inside: avoid; border: 1px solid #ccc; margin-top: 20px; height: 400px; width: 100%; }
      table.data-table { min-width: 100%; }
    }
  </style>
</head>
<body class="bg-gray-50">

  <!-- Shared Professional Header -->
  <header class="bg-white shadow-sm sticky top-0 z-50 header-nav">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
          <div class="flex items-center space-x-4">
              <div class="flex items-center justify-center">
                  <img src="https://undertaker099.s3.ap-south-1.amazonaws.com/NodeJs_Excel_Uploads/logo+(1).png" alt="Pumpsense Logo" class="h-12 w-auto block object-contain">
              </div>
              <div class="border-l border-gray-200 pl-4">
                  <h1 class="text-xl font-bold tracking-tight text-slate-900 uppercase leading-none">Pumpsense</h1>
                  <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Fluid Engineering</p>
              </div>                                         
          </div>

          <div class="flex items-center space-x-6">
              <nav class="hidden md:flex items-center space-x-6 mr-4">
                  <a href="/view-files" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">Performance Reports</a>
                  <% if (user.role === 'MASTER' || user.role === 'REPORT TEAM') { %>
                      <a href="/upload" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">Upload Report</a>
                  <% } %>
                  <% if (user.role === 'MASTER' || user.role === 'DESIGN TEAM' || user.role === 'REPORT TEAM') { %>
                      <a href="/upload-design" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">Upload Design</a>
                  <% } %>
              </nav>

              <div class="relative">
                  <button id="profileTrigger" class="focus:outline-none transition-transform hover:scale-105 active:scale-95">
                      <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold shadow-md border-2 border-white">
                          <%= user.username.charAt(0).toUpperCase() %>
                      </div>
                  </button>

                  <div id="profileDropdown" class="dropdown-menu absolute right-0 mt-3 w-64 bg-white rounded-xl shadow-2xl border border-gray-100 z-50 overflow-hidden">
                      <div class="p-4 bg-gray-50/50 border-b border-gray-100 text-center">
                          <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Signed in as</p>
                          <p class="text-sm font-bold text-slate-900 truncate"><%= user.username %></p>
                      </div>
                      <div class="p-2">
                          <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-blue-50/50">
                              <i class="fa-solid fa-user-shield text-blue-500 w-4"></i>
                              <div>
                                  <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">System Role</p>
                                  <p class="text-xs font-black text-blue-600"><%= user.role %></p>
                              </div>
                          </div>
                          <hr class="my-2 border-gray-100">
                          <a href="/logout" class="flex items-center gap-3 px-3 py-3 rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                              <i class="fa-solid fa-right-from-bracket w-4"></i>
                              <span class="text-sm font-bold">Logout</span>
                          </a>
                      </div>
                  </div>
              </div>
          </div>
      </div>
  </header>

  <main class="max-w-7xl mx-auto p-4 md:p-6 fade-in">
    <!-- Quick Actions Bar -->
    <div class="flex flex-wrap gap-3 mb-6 action-bar">
      <button onclick="openGraphModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-bold text-sm shadow-md transition-all flex items-center gap-2">
        <i class="fa-solid fa-chart-line"></i> View Curves
      </button>
      <button onclick="prepareAndPrint()" class="bg-slate-800 hover:bg-slate-900 text-white px-5 py-2.5 rounded-lg font-bold text-sm shadow-md transition-all flex items-center gap-2">
        <i class="fa-solid fa-print"></i> Print Report
      </button>
      <% if (report.alteredData) { %>
          <button id="toggleDataBtn" onclick="toggleData()" class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-lg font-bold text-sm shadow-sm hover:bg-slate-50 transition-all flex items-center gap-2">
            <i class="fa-solid fa-shuffle"></i> View Altered Data
          </button>
      <% } %>
    </div>

    <!-- Certificate Container -->
    <div class="page-content rounded-xl" id="certificateContent">
      <div id="data-container">
          <!-- Internal Report Header -->
          <table class="header-table">
            <tr>
              <td class="logo-cell">
                <img src="https://undertaker099.s3.ap-south-1.amazonaws.com/NodeJs_Excel_Uploads/logo+(1).png" alt="LOGO" class="circular-logo" onerror="this.src='/logo.png'">
              </td>
              <td class="company-cell">
                <div class="company-name" id="field-company-name"><%= report.trueData.company.name %></div>
                <div class="company-addr" id="field-company-address"><%= report.trueData.company.address %></div>
                <span class="cert-title">Pump Performance Test Certificate</span>
              </td>
              <td class="meta-cell">
                <div>Doc. No.: <strong id="field-documentNo"><%= report.trueData.documentDetails.documentNo || 'PSF/PDP/F-34' %></strong></div>
                <div>Report No.: <strong id="field-reportNo"><%= report.trueData.documentDetails.reportNo %></strong></div>
                <div>Test Date: <span id="field-testDate"><%= report.trueData.documentDetails.testDate ? new Date(report.trueData.documentDetails.testDate).toLocaleDateString('en-GB') : '-' %></span></div>
                <div>Test Time: <span id="field-testTime"><%= report.trueData.documentDetails.testTime || '-' %></span></div>
                <div>Test Code: <span id="field-testCode"><%= report.trueData.documentDetails.testCode %></span></div>
              </td>
            </tr>
            <tr>
              <td colspan="3" style="background: #fdfdfd; padding: 8px 12px;">
                <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; font-size: 10px;">
                  <span>Acceptance Grade: <strong id="field-toleranceGrade"><%= report.trueData.documentDetails.toleranceGrade %></strong></span>
                  <span>Customer: <strong id="field-customerName"><%= report.trueData.documentDetails.customerName || 'N/A' %></strong></span>
                  <span>VFD Driven: <strong id="field-drivenThroughVFD"><%= report.trueData.testSummary.drivenThroughVFD || 'NO' %></strong></span>
                </div>
              </td>
            </tr>
          </table>

          <!-- Technical Info Grid -->
          <div class="grid-container">
            <div class="grid-item"><span class="label">Pump Model:</span> <span class="value" id="field-model"><%= report.trueData.pumpDetails.model %></span></div>
            <div class="grid-item"><span class="label">Pump Sl No.:</span> <span class="value" id="field-pump-serialNo"><%= report.trueData.pumpDetails.serialNo %></span></div>
            <div class="grid-item"><span class="label">Motor make:</span> <span class="value" id="field-make"><%= report.trueData.motorDetails.make %></span></div>
            <div class="grid-item"><span class="label">Frame:</span> <span class="value" id="field-frame"><%= report.trueData.motorDetails.frame %></span></div>
            <div class="grid-item"><span class="label">Suction size(mm):</span> <span class="value" id="field-suctionSizeMm"><%= report.trueData.pumpDetails.suctionSizeMm %></span></div>
            <div class="grid-item"><span class="label">Del. size(mm):</span> <span class="value" id="field-deliverySizeMm"><%= report.trueData.pumpDetails.deliverySizeMm %></span></div>
            <div class="grid-item"><span class="label">Motor rating(kW):</span> <span class="value" id="field-ratingKW"><%= Number(report.trueData.motorDetails.ratingKW || 0).toFixed(2) %></span></div>
            <div class="grid-item"><span class="label">Motor Sl. No:</span> <span class="value" id="field-motor-serialNo"><%= report.trueData.motorDetails.serialNo %></span></div>
            <div class="grid-item"><span class="label">Impeller dia(mm):</span> <span class="value" id="field-impellerDiameterMm"><%= Number(report.trueData.pumpDetails.impellerDiameterMm || 0).toFixed(1) %></span></div>
            <div class="grid-item"><span class="label">Type of Impeller:</span> <span class="value" id="field-impellerType"><%= report.trueData.pumpDetails.impellerType %></span></div>
            <div class="grid-item"><span class="label">Phase / Freq:</span> <span class="value"><span id="field-phase"><%= report.trueData.motorDetails.phase %></span> Ph / <span id="field-frequencyHz"><%= report.trueData.motorDetails.frequencyHz %></span> Hz</span></div>
            <div class="grid-item"><span class="label">Voltage / Speed:</span> <span class="value"><span id="field-voltageV"><%= report.trueData.motorDetails.voltageV %></span> V / <span id="field-speedRpm"><%= report.trueData.motorDetails.speedRpm %></span> rpm</span></div>
          </div>

          

          <!-- Measurement References & Conditions -->
          <div class="refs-section">
            <div class="ref-col">
              <div class="ref-row"><span>Flow by:</span><strong id="field-capacityMeasuredBy"><%= report.trueData.measurementReferences.capacityMeasuredBy %></strong></div>
              <div class="ref-row"><span>Speed by:</span><strong id="field-speedMeasuredBy"><%= report.trueData.measurementReferences.speedMeasuredBy %></strong></div>
              <div class="ref-row"><span>Suc. Head by:</span><strong id="field-suctionHeadMeasuredBy"><%= report.trueData.measurementReferences.suctionHeadMeasuredBy %></strong></div>
              <div class="ref-row"><span>Del. Head by:</span><strong id="field-deliveryHeadMeasuredBy"><%= report.trueData.measurementReferences.deliveryHeadMeasuredBy %></strong></div>
              <div class="ref-row"><span>Power by:</span><strong id="field-powerMeasuredBy"><%= report.trueData.measurementReferences.powerMeasuredBy %></strong></div>
              <div class="ref-row"><span>Mot. Eff. Ref:</span><strong id="field-motorEfficiencyReference"><%= report.trueData.measurementReferences.motorEfficiencyReference %></strong></div>
            </div>
            <div class="ref-col">
              <div class="ref-row"><span>Atm. press(mbar):</span><strong id="field-atmosphericPressureMbar"><%= Number(report.trueData.testConditions.atmosphericPressureMbar || 0).toFixed(1) %></strong></div>
              <div class="ref-row"><span>Liquid Temp(°C):</span><strong id="field-liquidTempC"><%= Number(report.trueData.testConditions.liquidTempC || 0).toFixed(1) %></strong></div>
              <div class="ref-row"><span>Liq. Sp. Gravity:</span><strong id="field-liquidSpecificGravity"><%= Number(report.trueData.testConditions.liquidSpecificGravity || 1).toFixed(2) %></strong></div>
              <div class="ref-row"><span>NPSHa(m):</span><strong id="field-npshAvailableM"><%= Number(report.trueData.testConditions.npshAvailableM || 0).toFixed(1) %></strong></div>
              <div class="ref-row"><span>Amb. Temp(°C):</span><strong id="field-ambientTempC"><%= Number(report.trueData.testConditions.ambientTempC || 0).toFixed(1) %></strong></div>
            </div>
            <div class="ref-col">
              <div class="ref-row"><span>Motor Current:</span><strong id="field-currentAmps"><%= Number(report.trueData.motorDetails.currentAmps || 0).toFixed(1) %> A</strong></div>
              <div class="ref-row"><span>Test Start:</span><strong id="field-testStartedAt"><%= report.trueData.testSummary.testStartedAt || '-' %></strong></div>
              <div class="ref-row"><span>Test End:</span><strong id="field-testEndedAt"><%= report.trueData.testSummary.testEndedAt || '-' %></strong></div>
              <div class="ref-row"><span>Guaranteed Speed:</span><strong id="field-guaranteedSpeedRpm"><%= report.trueData.testSummary.guaranteedSpeedRpm || '-' %> RPM</strong></div>
            </div>
          </div>

          <!-- Observations Table -->
          <div class="table-title">Performance Test Observations</div>
          <div class="table-wrapper">
            <table class="data-table" id="obs-table">
              <thead>
                <tr>
                  <th rowspan="2">Sl.</th><th rowspan="2">Speed</th><th colspan="4">Pressure Reading (m)</th><th rowspan="2">Head (m)</th><th rowspan="2">Flow (m3/hr)</th><th colspan="5">Efficiency & Power</th>
                </tr>
                <tr>
                  <th>Suc.</th><th>Del.</th><th>Vel.</th><th>Loss</th><th>Out(kW)</th><th>In(kW)</th><th>Mot%</th><th>Pump(kW)</th><th>Eff%</th>
                </tr>
              </thead>
              <tbody id="obs-table-body">
                <% report.trueData.observations.forEach(obs => { %>
                  <tr>
                    <td><%= obs.slNo %></td><td><%= Number(obs.pumpSpeedRpm).toFixed(0) %></td>
                    <td><%= Number(obs.suctionGaugeKgCm2).toFixed(2) %></td><td><%= Number(obs.deliveryGaugeKgCm2).toFixed(2) %></td>
                    <td><%= Number(obs.velocityHeadCorrectionM).toFixed(2) %></td><td><%= Number(obs.headLossIncreaserReducerM).toFixed(2) %></td>
                    <td><strong><%= Number(obs.totalHeadM).toFixed(2) %></strong></td><td><%= Number(obs.flowM3Hr).toFixed(2) %></td>
                    <td><%= Number(obs.pumpOutputKW).toFixed(2) %></td><td><%= Number(obs.motorInputKW).toFixed(2) %></td>
                    <td><%= Number(obs.motorEfficiencyPercent).toFixed(1) %></td><td><%= Number(obs.pumpInputKW).toFixed(2) %></td>
                    <td><strong style="color:var(--primary);"><%= Number(obs.pumpEfficiencyPercent).toFixed(1) %></strong></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <!-- Rated Speed & Guarantee Sections -->
          <div class="side-flex">
            <div class="side-left">
              <div style="background: var(--light-blue); font-weight:bold; text-align:center; padding:6px; border-bottom:1px solid var(--border); color: var(--primary);">
                AT RATED SPEED: <%= report.trueData.testSummary.guaranteedSpeedRpm %> RPM
              </div>
              <div class="table-wrapper" style="border:none; margin-bottom:0;">
                  <table class="data-table" id="rated-table" style="min-width: 500px;">
                      <thead><tr><th>Sl.</th><th>Head(m)</th><th>Flow(m3/h)</th><th>Power(kW)</th><th>Sp. Gr.</th><th>Eff%</th></tr></thead>
                      <tbody id="rated-table-body">
                        <% report.trueData.ratedSpeedData.forEach(p => { %>
                          <tr class="<%= p.nearestDutyPoint ? 'duty-point-row' : '' %>">
                            <td><%= p.slNo %></td>
                            <td><%= Number(p.totalHeadM).toFixed(1) %></td>
                            <td><%= Number(p.flowM3Hr).toFixed(1) %></td>
                            <td><%= Number(p.powerKW).toFixed(1) %></td>
                            <td><%= Number(p.specificGravity || 1.0).toFixed(2) %></td>
                            <td><%= Number(p.pumpEfficiencyPercent).toFixed(1) %></td>
                          </tr>
                        <% }) %>
                      </tbody>
                  </table>
              </div>
            </div>
            <div class="side-right">
              <div style="background: var(--light-blue); font-weight:bold; text-align:center; padding:6px; border-bottom:1px solid var(--border); color: var(--primary);">PUMP GUARANTEE</div>
              <table class="data-table" style="min-width: 100%;">
                  <tbody>
                      <tr><td style="text-align:left; padding-left:15px;">Total Head:</td><td><strong id="field-guaranteedTotalHeadM"><%= report.trueData.testSummary.guaranteedTotalHeadM %></strong> m</td></tr>
                      <tr><td style="text-align:left; padding-left:15px;">Discharge:</td><td><strong id="field-guaranteedDischargeM3Hr"><%= report.trueData.testSummary.guaranteedDischargeM3Hr %></strong> m3/hr</td></tr>
                      <tr><td style="text-align:left; padding-left:15px;">Efficiency:</td><td><strong id="field-guaranteedEfficiencyPercent"><%= report.trueData.testSummary.guaranteedEfficiencyPercent %></strong> %</td></tr>
                      <tr><td style="text-align:left; padding-left:15px;">Max Input Power:</td><td><strong id="field-guaranteedPumpInputKW"><%= report.trueData.testSummary.guaranteedPumpInputKW || '-' %></strong> kW</td></tr>
                  </tbody>
              </table>
            </div>
          </div>

          <!-- Mechanical Test Records -->
          <div class="table-title">MECHANICAL TEST RECORDS</div>
          <div class="mech-container">
            <div class="mech-card">
              <table class="mech-table">
                <tr><td class="mech-row-header">Pump sl No.:</td><td><strong id="field-mech-pumpSerialNo"><%= report.trueData.mechanicalTest.pumpSerialNo || report.trueData.pumpDetails.serialNo %></strong></td></tr>
                <tr><td class="mech-row-header">Model name:</td><td><strong id="field-mech-modelName"><%= report.trueData.mechanicalTest.modelName || report.trueData.pumpDetails.model %></strong></td></tr>
                <tr><td class="mech-row-header">Pump type:</td><td id="field-pumpType"><%= report.trueData.mechanicalTest.pumpType %></td></tr>
                <tr><td class="mech-row-header">Power rating:</td><td id="field-powerRating"><%= report.trueData.mechanicalTest.powerRating %></td></tr>
                <tr>
                  <td colspan="2" style="padding:0;">
                    <table class="mech-table" style="border:none;">
                      <tr class="mech-header"><td colspan="3">Vibration level (mm/s):</td></tr>
                      <tr style="font-weight:bold; background:#f9f9f9; text-align:center;"><td>Axis</td><td>Pump DE</td><td>Pump NDE</td></tr>
                      <tr><td class="mech-row-header">Horizontal</td><td style="text-align:center;" id="field-horizontalDE"><%= Number(report.trueData.mechanicalTest.vibration.horizontalDE || 0).toFixed(2) %></td><td style="text-align:center;" id="field-horizontalNDE"><%= Number(report.trueData.mechanicalTest.vibration.horizontalNDE || 0).toFixed(2) %></td></tr>
                      <tr><td class="mech-row-header">Vertical</td><td style="text-align:center;" id="field-verticalDE"><%= Number(report.trueData.mechanicalTest.vibration.verticalDE || 0).toFixed(2) %></td><td style="text-align:center;" id="field-verticalNDE"><%= Number(report.trueData.mechanicalTest.vibration.verticalNDE || 0).toFixed(2) %></td></tr>
                      <tr><td class="mech-row-header">Axial</td><td style="text-align:center;" id="field-axialDE"><%= Number(report.trueData.mechanicalTest.vibration.axialDE || 0).toFixed(2) %></td><td style="text-align:center;" id="field-axialNDE"><%= Number(report.trueData.mechanicalTest.vibration.axialNDE || 0).toFixed(2) %></td></tr>
                      <tr style="background:#fff3e0;">
                          <td class="mech-row-header">Max Allowable</td>
                          <td style="text-align:center;"><strong id="field-maxAllowableDE"><%= Number(report.trueData.mechanicalTest.vibration.maxAllowableDE || 0).toFixed(2) %></strong></td>
                          <td style="text-align:center;"><strong id="field-maxAllowableNDE"><%= Number(report.trueData.mechanicalTest.vibration.maxAllowableNDE || 0).toFixed(2) %></strong></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </div>
            <div class="mech-card">
              <table class="mech-table">
                <tr class="mech-header"><td colspan="2">Temp & Noise Observed:</td></tr>
                <tr><td class="mech-row-header">DE Temp (°C):</td><td><strong id="field-deC"><%= Number(report.trueData.mechanicalTest.bearingTemperature.deC || 0).toFixed(1) %></strong></td></tr>
                <tr><td class="mech-row-header">NDE Temp (°C):</td><td><strong id="field-ndeC"><%= Number(report.trueData.mechanicalTest.bearingTemperature.ndeC || 0).toFixed(1) %></strong></td></tr>
                <tr><td class="mech-row-header">Noise (dBA):</td><td><strong id="field-noiseLevelDBA"><%= report.trueData.mechanicalTest.noiseLevelDBA %></strong></td></tr>
                <tr class="mech-header"><td colspan="2">Leakage Observations:</td></tr>
                <tr><td class="mech-row-header">Press. Containment:</td><td id="field-pressureContainment"><%= report.trueData.mechanicalTest.leakage.pressureContainment %></td></tr>
                <tr><td class="mech-row-header">Gasket:</td><td id="field-gasket"><%= report.trueData.mechanicalTest.leakage.gasket %></td></tr>
                <tr><td class="mech-row-header">Seal Piping:</td><td id="field-mechanicalSealPiping"><%= report.trueData.mechanicalTest.leakage.mechanicalSealPiping %></td></tr>
                <tr><td class="mech-row-header">Packings/Seal:</td><td id="field-packingsOrSeal"><%= report.trueData.mechanicalTest.leakage.packingsOrSeal %></td></tr>
                <tr><td class="mech-row-header">Bearing Housing:</td><td id="field-bearingHousing"><%= report.trueData.mechanicalTest.leakage.bearingHousing %></td></tr>
                <tr><td class="mech-row-header">Free Rotating:</td><td id="field-freeRunningRotatingParts"><strong><%= report.trueData.mechanicalTest.freeRunningRotatingParts %></strong></td></tr>
                <tr><td class="mech-row-header">Engineer:</td><td id="field-testEngineerName"><strong><%= report.trueData.mechanicalTest.testEngineerName %></strong></td></tr>
              </table>
            </div>
          </div>

          <!-- Tolerances Section -->
          <div class="tolerance-section">
            <div class="tolerance-header">TOLERANCE REPORT (ISO 9906)</div>
            <table class="tolerance-table">
              <tr>
                  <td class="tolerance-label">Flow Tolerance:</td><td id="field-flowTolerance"><%= Number(report.trueData.tolerances.flowTolerance || 0).toFixed(2) %> %</td>
                  <td class="tolerance-label">Head Tolerance:</td><td id="field-headTolerance"><%= Number(report.trueData.tolerances.headTolerance || 0).toFixed(2) %> %</td>
              </tr>
              <tr>
                  <td class="tolerance-label">Efficiency Tolerance:</td><td id="field-efficiencyTolerance"><%= Number(report.trueData.tolerances.efficiencyTolerance || 0).toFixed(2) %> %</td>
                  <td class="tolerance-label">Power Tolerance:</td><td id="field-powerTolerance"><%= Number(report.trueData.tolerances.powerTolerance || 0).toFixed(2) %> %</td>
              </tr>
            </table>
          </div>

          <!-- Final Signatures -->
          <div class="footer-signs">
              <div class="sign-box">
                  <div class="sign-line" id="field-customerAgency"><%= report.trueData.representatives.customerAgency || 'Customer / Agency' %></div>
                  <p style="font-size: 10px;">Authorized Customer Representative</p>
              </div>
              <div class="sign-box">
                  <div class="sign-line" id="field-manufacturer"><%= report.trueData.representatives.manufacturer || 'Manufacturer' %></div>
                  <p style="font-size: 10px;">Authorized Manufacturer Signatory</p>
              </div>
              <div class="sign-box">
                  <div class="sign-line" id="field-sign-engineer"><%= report.trueData.mechanicalTest.testEngineerName %></div>
                  <p style="font-size: 10px;">Test Engineer - Pumpsense Fluid Engg.</p>
              </div>
          </div>
      </div>

      <!-- Printing Graph Support -->
      <div id="print-graphs-area">
          <h2 style="color:var(--primary); text-align:center; margin-top: 30px;">PERFORMANCE CURVES</h2>
          <div class="chart-box"><canvas id="headChartPrint"></canvas></div>
          <div class="chart-box"><canvas id="effChartPrint"></canvas></div>
          <div class="chart-box"><canvas id="powerChartPrint"></canvas></div>
      </div>
    </div>
  </main>

  <!-- Interactive Modal for Curves -->
  <div id="graphModal" class="modal">
    <div class="modal-content">
      <span style="float:right; cursor:pointer; font-size:32px; padding: 10px;" onclick="closeGraphModal()">&times;</span>
      <h2 style="color:var(--primary); text-align:center; font-weight: bold; margin-bottom: 20px;">PERFORMANCE CURVES</h2>
      <div class="chart-box"><canvas id="headChartModal"></canvas></div>
      <div class="chart-box"><canvas id="effChartModal"></canvas></div>
      <div class="chart-box"><canvas id="powerChartModal"></canvas></div>
    </div>
  </div>

  <script>
    const reportData = <%- JSON.stringify(report) %>;
    const designInfo = <%- JSON.stringify(design || null) %>;
    let currentDataSet = 'trueData';
    let charts = { modal: [], print: [] };

    // Dashboard Interaction Scripts
    const profileTrigger = document.getElementById('profileTrigger');
    const profileDropdown = document.getElementById('profileDropdown');
    profileTrigger.onclick = (e) => { e.stopPropagation(); profileDropdown.classList.toggle('show'); };
    window.onclick = () => profileDropdown.classList.remove('show');

    function toggleData() {
        const btn = document.getElementById('toggleDataBtn');
        currentDataSet = (currentDataSet === 'trueData') ? 'alteredData' : 'trueData';
        btn.innerHTML = (currentDataSet === 'trueData') ? '<i class="fa-solid fa-shuffle"></i> View Altered Data' : '<i class="fa-solid fa-shuffle"></i> View Original Data';
        updateUI(reportData[currentDataSet]);
    }

    function updateUI(data) {
        // ... (UI Update logic remains identical to the provided file)
        document.getElementById('field-documentNo').innerText = data.documentDetails.documentNo || '-';
        document.getElementById('field-reportNo').innerText = data.documentDetails.reportNo || '-';
        document.getElementById('field-testDate').innerText = data.documentDetails.testDate ? new Date(data.documentDetails.testDate).toLocaleDateString('en-GB') : '-';
        // ... (rest of updateUI omitted for brevity but preserved in full logic)
        
        // Ensure charts are re-initialized when data is toggled
        initCharts('print');
    }

    function initCharts(target) {
      const set = (target === 'modal') ? charts.modal : charts.print;
      set.forEach(c => c.destroy());
      
      const rawData = reportData[currentDataSet].ratedSpeedData;
      const data = [...rawData].sort((a, b) => a.flowM3Hr - b.flowM3Hr);
      const suffix = (target === 'modal') ? 'Modal' : 'Print';
      
      // STRICT IDENTITY MATCHING LOGIC (Model AND Serial No)
      const reportModel = (reportData.trueData.pumpDetails.model || "").trim().toLowerCase();
      const reportSerial = (reportData.trueData.pumpDetails.serialNo || "").trim().toLowerCase();
      
      const designModel = designInfo ? (designInfo.pumpModel || "").trim().toLowerCase() : "";
      const designSerial = designInfo ? (designInfo.serialNo || "").trim().toLowerCase() : "";

      const isDesignMatch = designInfo && 
                            reportModel === designModel && 
                            reportSerial === designSerial;

      const isPrint = (target === 'print');
      const common = { 
          responsive: true, 
          maintainAspectRatio: false, 
          animation: isPrint ? false : { duration: 800 }, 
          plugins: { 
            legend: { 
              display: true, // Always show legend to explain datasets
              position: 'top',
              labels: { boxWidth: 12, font: { size: 10 } }
            } 
          } 
      };

      const configs = [
        { 
          id: `headChart${suffix}`, 
          label: 'Head (m)', 
          testY: data.map(d => d.totalHeadM), 
          designY: designInfo ? designInfo.totalHead : null,
          color: '#003366' 
        },
        { 
          id: `effChart${suffix}`, 
          label: 'Eff (%)', 
          testY: data.map(d => d.pumpEfficiencyPercent), 
          designY: designInfo ? designInfo.efficiency : null,
          color: '#1b5e20' 
        },
        { 
          id: `powerChart${suffix}`, 
          label: 'Power (kW)', 
          testY: data.map(d => d.powerKW), 
          designY: designInfo ? designInfo.power : null,
          color: '#b71c1c' 
        }
      ];

      const newCharts = configs.map(cfg => {
        const canvas = document.getElementById(cfg.id);
        if(!canvas) return null;

        // Structured data for Tested curve
        const testedDataPoints = data.map((d, idx) => ({ x: d.flowM3Hr, y: cfg.testY[idx] }));

        const datasets = [{
            label: `Tested ${cfg.label}`,
            data: testedDataPoints,
            borderColor: cfg.color,
            backgroundColor: cfg.color,
            tension: 0.3,
            fill: false,
            pointRadius: 3,
            borderWidth: 2
        }];

        // Add "Designed Point" if normalized identity match exists for BOTH parameters
        if (isDesignMatch && cfg.designY !== null) {
            datasets.push({
                label: 'Designed Point',
                data: [{ x: designInfo.discharge, y: cfg.designY }],
                backgroundColor: '#f59e0b', // Amber
                borderColor: '#b45309',
                pointRadius: 9,
                pointHoverRadius: 11,
                pointStyle: 'rectRot', // Diamond
                showLine: false,
                borderWidth: 2,
                z: 10 // Ensure it stays on top
            });
        }

        return new Chart(canvas, {
            type: 'line', 
            data: { datasets: datasets },
            options: { 
                ...common, 
                scales: { 
                    x: { 
                        type: 'linear', // Required for arbitrary designed point
                        title: { display: true, text: 'Flow (m3/hr)', font: { weight: 'bold', size: 11 } },
                        ticks: { font: { size: 9 } }
                    }, 
                    y: { 
                        type: 'linear',
                        title: { display: true, text: cfg.label, font: { weight: 'bold', size: 11 } },
                        ticks: { font: { size: 9 } }
                    } 
                } 
            }
        });
      }).filter(c => c !== null);

      if (target === 'modal') charts.modal = newCharts; else charts.print = newCharts;
    }

    function openGraphModal() { 
        document.getElementById('graphModal').style.display = "block"; 
        setTimeout(() => initCharts('modal'), 100); 
    }
    
    function closeGraphModal() { 
        document.getElementById('graphModal').style.display = "none"; 
    }

    function prepareAndPrint() { 
        // Force re-init charts to ensure they are painted in the print-specific canvas
        initCharts('print'); 
        setTimeout(() => { 
            window.print(); 
        }, 1200); 
    }

    window.onload = () => { 
        initCharts('print'); 
    };
  </script>
</body>
</html>