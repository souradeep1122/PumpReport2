<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PUMPSENSE | <%= typeof design !== 'undefined' ? 'Edit' : 'Upload' %> Design Specification</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .fade-in { animation: fadeIn 0.3s ease-out forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Dropdown transition */
        .dropdown-menu {
            display: none;
            opacity: 0;
            transform: translateY(-10px);
            transition: opacity 0.2s ease, transform 0.2s ease;
        }
        .dropdown-menu.show {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 min-h-screen flex flex-col font-sans">

    <% const isEdit = typeof design !== 'undefined' && design; %>

    <!-- Header (Consistent with Dashboard) -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
            <!-- Logo & Title Section -->
            <div class="flex items-center space-x-4">
                <div class="flex items-center justify-center">
                    <img src="https://undertaker099.s3.ap-south-1.amazonaws.com/NodeJs_Excel_Uploads/logo+(1).png" alt="Pumpsense Logo" class="h-12 w-auto block object-contain">
                </div>
                <div class="border-l border-gray-200 pl-4">
                    <h1 class="text-xl font-bold tracking-tight text-slate-900 uppercase leading-none">Pumpsense</h1>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Fluid Engineering</p>
                </div>                                         
            </div>

            <!-- Navigation & Account -->
            <div class="flex items-center space-x-6">
                <nav class="hidden md:flex items-center space-x-6 mr-4">
                    <a href="/view-files" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">Performance Reports</a>
                    <% if (user.role === 'MASTER' || user.role === 'REPORT TEAM') { %>
                        <a href="/upload" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">Upload Report</a>
                    <% } %>
                </nav>

                <!-- Profile Trigger -->
                <div class="relative">
                    <button id="profileTrigger" class="focus:outline-none transition-transform hover:scale-105 active:scale-95">
                        <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold shadow-md border-2 border-white">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                    </button>

                    <!-- Dropdown Menu -->
                    <div id="profileDropdown" class="dropdown-menu absolute right-0 mt-3 w-64 bg-white rounded-xl shadow-2xl border border-gray-100 z-50 overflow-hidden">
                        <div class="p-4 bg-gray-50/50 border-b border-gray-100 text-center">
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Signed in as</p>
                            <p class="text-sm font-bold text-slate-900 truncate"><%= user.username %></p>
                        </div>
                        <div class="p-2">
                            <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-blue-50/50">
                                <i class="fa-solid fa-user-shield text-blue-500 w-4"></i>
                                <div>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">System Role</p>
                                    <p class="text-xs font-black text-blue-600"><%= user.role %></p>
                                </div>
                            </div>
                            <hr class="my-2 border-gray-100">
                            <a href="/logout" class="flex items-center gap-3 px-3 py-3 rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                                <i class="fa-solid fa-right-from-bracket w-4"></i>
                                <span class="text-sm font-bold">Logout</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col items-center justify-center p-4">
        <div class="w-full max-w-2xl fade-in">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-slate-100">
                
                <!-- Banner Header -->
                <div class="bg-blue-600 p-8 text-white">
                    <div class="flex justify-between items-start">
                        <div>
                            <h2 class="text-2xl font-bold"><%= isEdit ? 'Edit Pump Design' : 'New Pump Design Entry' %></h2>
                            <p class="text-blue-100 text-sm mt-1">
                                <%= isEdit ? 'Update existing master design specifications.' : 'Register master design specifications for performance comparison.' %>
                            </p>
                        </div>
                        <div class="bg-blue-500/50 px-3 py-1 rounded text-[10px] font-black tracking-widest uppercase">
                            <%= isEdit ? 'Edit Mode' : 'Design Mode' %>
                        </div>
                    </div>
                </div>

                <!-- Error Messages -->
                <% if (typeof message !== 'undefined' && message && message.length > 0) { %>
                    <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 m-6 rounded-r" role="alert">
                        <div class="flex items-center">
                            <i class="fa-solid fa-circle-exclamation mr-2"></i>
                            <p class="font-bold">Entry Error</p>
                        </div>
                        <p class="text-sm mt-1 ml-7"><%= message %></p>
                    </div>
                <% } %>

                <form action="<%= isEdit ? '/update-design/' + design._id : '/upload-design' %>" method="POST" class="p-8 space-y-8">
                    <!-- Row 1: Identification -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-black uppercase text-slate-500 mb-2 tracking-wider">Pump Model</label>
                            <input type="text" name="pumpModel" required
                                value="<%= isEdit ? design.pumpModel : '' %>"
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white outline-none transition-all placeholder:text-slate-300"
                                placeholder="e.g. CentriFlow-X500">
                        </div>
                        <div>
                            <label class="block text-xs font-black uppercase text-slate-500 mb-2 tracking-wider">Serial No.</label>
                            <input type="text" name="serialNo" required
                                value="<%= isEdit ? design.serialNo : '' %>"
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white outline-none transition-all placeholder:text-slate-300"
                                placeholder="e.g. SN-2023-089">
                        </div>
                    </div>

                    <div class="relative">
                        <div class="absolute inset-0 flex items-center" aria-hidden="true">
                            <div class="w-full border-t border-slate-100"></div>
                        </div>
                        <div class="relative flex justify-center text-sm font-bold uppercase tracking-widest text-slate-300">
                            <span class="bg-white px-4">Technical Specs</span>
                        </div>
                    </div>

                    <!-- Row 2: Performance Metrics -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="relative group">
                            <label class="block text-xs font-black uppercase text-slate-500 mb-2 tracking-wider">Discharge (m³/hr)</label>
                            <div class="relative">
                                <input type="number" step="0.01" name="discharge" min="0" required
                                    value="<%= isEdit ? design.discharge : '' %>"
                                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white outline-none transition-all">
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-slate-300">m³/hr</div>
                            </div>
                        </div>
                        <div class="relative group">
                            <label class="block text-xs font-black uppercase text-slate-500 mb-2 tracking-wider">Power (Kw)</label>
                            <div class="relative">
                                <input type="number" step="0.01" name="power" min="0" required
                                    value="<%= isEdit ? design.power : '' %>"
                                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white outline-none transition-all">
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-slate-300">KW</div>
                            </div>
                        </div>
                        <div class="relative group">
                            <label class="block text-xs font-black uppercase text-slate-500 mb-2 tracking-wider">Efficiency (%)</label>
                            <div class="relative">
                                <input type="number" step="0.1" name="efficiency" min="0" max="100" required
                                    value="<%= isEdit ? design.efficiency : '' %>"
                                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white outline-none transition-all">
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-slate-300">%</div>
                            </div>
                        </div>
                        <div class="relative group">
                            <label class="block text-xs font-black uppercase text-slate-500 mb-2 tracking-wider">Total Head (MWC)</label>
                            <div class="relative">
                                <input type="number" step="0.01" name="totalHead" min="0" required
                                    value="<%= isEdit ? design.totalHead : '' %>"
                                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white outline-none transition-all">
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-slate-300">MWC</div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer Actions -->
                    <div class="pt-6 flex flex-col md:flex-row gap-4">
                        <button type="submit" 
                            class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg hover:shadow-xl transition-all active:scale-95 flex items-center justify-center space-x-2">
                            <i class="fa-solid fa-cloud-arrow-up"></i>
                            <span><%= isEdit ? 'Update Design Specification' : 'Save Design Specification' %></span>
                        </button>
                        
                        <% if (isEdit && user.role === 'MASTER') { %>
                            <button type="button" onclick="handleDelete('<%= design._id %>')"
                                class="px-8 py-4 bg-red-50 text-red-600 font-bold rounded-xl hover:bg-red-100 transition-all text-center flex items-center justify-center space-x-2">
                                <i class="fa-solid fa-trash-can"></i>
                                <span>Delete</span>
                            </button>
                        <% } %>

                        <a href="/view-files" class="px-8 py-4 border border-slate-200 text-slate-500 font-bold rounded-xl hover:bg-slate-50 transition-all text-center">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
            
            <p class="text-center text-slate-400 text-[10px] font-black uppercase tracking-widest mt-10">
                &copy; 2024 PumpSense Engineering Systems • Fluid Engineering Excellence
            </p>
        </div>
    </main>

    <script>
        // Dropdown Logic
        const profileTrigger = document.getElementById('profileTrigger');
        const profileDropdown = document.getElementById('profileDropdown');

        profileTrigger.addEventListener('click', (e) => {
            e.stopPropagation();
            profileDropdown.classList.toggle('show');
        });

        window.addEventListener('click', () => {
            if (profileDropdown.classList.contains('show')) {
                profileDropdown.classList.remove('show');
            }
        });

        // Delete Logic
        async function handleDelete(id) {
            if (!confirm("Are you sure you want to permanently delete this design specification? This cannot be undone.")) return;
            
            try {
                const response = await fetch(`/delete-design/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const result = await response.json();
                
                if (result.success) {
                    window.location.href = '/view-files';
                } else {
                    alert("Delete failed: " + result.message);
                }
            } catch (err) {
                alert("An error occurred during deletion.");
            }
        }
    </script>
</body>
</html>