<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PUMPSENSE | Performance Reports</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .fade-in { animation: fadeIn 0.3s ease-out forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .custom-scrollbar::-webkit-scrollbar { height: 8px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        /* Dropdown transition */
        .dropdown-menu {
            display: none;
            opacity: 0;
            transform: translateY(-10px);
            transition: opacity 0.2s ease, transform 0.2s ease;
        }
        .dropdown-menu.show {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 min-h-screen flex flex-col font-sans">

    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
            <!-- Logo & Title Section -->
            <div class="flex items-center space-x-4">
                <!-- Official Company Logo Container -->
                <div class="flex items-center justify-center">
                    <img src="https://undertaker099.s3.ap-south-1.amazonaws.com/NodeJs_Excel_Uploads/logo+(1).png" alt="Pumpsense Logo" class="h-12 w-auto block object-contain">
                </div>
                
                <div class="border-l border-gray-200 pl-4">
                    <h1 class="text-xl font-bold tracking-tight text-slate-900 uppercase leading-none">Pumpsense</h1>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Fluid Engineering</p>
                </div>                                         
            </div>

            <!-- Navigation & Account -->
            <div class="flex items-center space-x-6">
                <nav class="hidden md:flex items-center space-x-6 mr-4">
                    <% if (user && user.role === 'admin') { %>
                        <a href="/" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">Upload</a>
                    <% } %>
                    <a href="/view-files" class="text-sm font-bold text-blue-600 border-b-2 border-blue-600 pb-0.5">Performance Reports</a>
                </nav>

                <!-- Small Profile Trigger & Detailed Dropdown -->
                <div class="relative">
                    <button id="profileTrigger" class="focus:outline-none transition-transform hover:scale-105 active:scale-95">
                        <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold shadow-md border-2 border-white">
                            <%= (typeof user !== 'undefined' && user.username) ? user.username.charAt(0).toUpperCase() : 'A' %>
                        </div>
                    </button>

                    <!-- Dropdown Menu -->
                    <div id="profileDropdown" class="dropdown-menu absolute right-0 mt-3 w-56 bg-white rounded-xl shadow-2xl border border-gray-100 z-50 overflow-hidden">
                        <div class="p-4 bg-gray-50/50 border-b border-gray-100 text-center">
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Signed in as</p>
                            <p class="text-sm font-bold text-slate-900 truncate">
                                <%= (typeof user !== 'undefined' && user) ? user.username : 'Admin User' %>
                            </p>
                        </div>
                        <div class="p-2">
                            <div class="flex items-center gap-3 px-3 py-2 rounded-lg">
                                <i class="fa-solid fa-shield-halved text-blue-500 w-4"></i>
                                <div>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Role</p>
                                    <p class="text-xs font-bold <%= user && user.role === 'admin' ? 'text-blue-600' : 'text-slate-600' %>">
                                        <%= (user && user.role) ? user.role.toUpperCase() : 'USER' %>
                                    </p>
                                </div>
                            </div>
                            
                            <hr class="my-2 border-gray-100">
                            
                            <a href="/logout" class="flex items-center gap-3 px-3 py-3 rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                                <i class="fa-solid fa-right-from-bracket w-4"></i>
                                <span class="text-sm font-bold">Logout</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col items-center p-4">
        
        <div class="w-full max-w-[98%] fade-in mt-4">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-slate-100">
                
                <!-- Title & Add Button -->
                <div class="p-6 border-b border-slate-100 flex flex-col sm:flex-row justify-between items-start sm:items-center bg-gray-50/50 gap-4">
                    <div>
                        <h2 class="text-xl font-bold text-slate-900">Database History</h2>
                        <p class="text-sm text-slate-500 mt-1">View and filter previously processed performance test certificates.</p>
                    </div>
                    
                    <% if (user && user.role === 'admin') { %>
                        <a href="/" class="inline-flex items-center justify-center w-full sm:w-auto rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-bold text-white shadow-md hover:bg-blue-700 transition-all hover:-translate-y-0.5">
                            <i class="fa-solid fa-plus mr-2"></i>
                            Upload New Comparison
                        </a>
                    <% } %>
                </div>
                
                <!-- Search & Filter Bar -->
                <div class="p-5 border-b border-slate-100 bg-white">
                    <div class="flex flex-col gap-6">
                        <div class="w-full max-w-md">
                            <label class="block text-xs font-bold uppercase text-slate-400 mb-1 tracking-wider">Search All Records</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 flex items-center pl-3">
                                    <i class="fa-solid fa-magnifying-glass text-slate-400 text-sm"></i>
                                </div>
                                <input type="text" id="searchInput" oninput="filterReports()" class="block w-full rounded-lg border-0 py-2.5 pl-10 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm bg-slate-50" placeholder="Model, Serial No, or Customer...">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 pt-4 border-t border-slate-100">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Pump Model</label>
                                <select id="modelFilter" onchange="filterReports()" class="block w-full rounded-md border-0 py-1.5 pl-3 text-slate-900 ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-blue-600 sm:text-sm">
                                    <option value="">All Models</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Impeller (mm)</label>
                                <input type="text" id="impellerFilter" oninput="filterReports()" class="block w-full rounded-md border-0 py-1.5 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="e.g. 300">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Test Date</label>
                                <input type="date" id="dateFilter" onchange="filterReports()" class="block w-full rounded-md border-0 py-1.5 text-slate-900 ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm">
                            </div>
                        </div>

                        <div class="flex items-center justify-between">
                            <span id="resultCount" class="text-xs font-bold text-blue-700 bg-blue-50 px-3 py-1 rounded-full">
                                Calculating...
                            </span>
                            <button onclick="resetFilters()" class="text-xs text-red-600 hover:text-red-800 font-bold uppercase tracking-wider transition-colors flex items-center">
                                <i class="fa-solid fa-filter-circle-xmark mr-1.5"></i>
                                Reset Filters
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Table -->
                <div class="overflow-x-auto min-h-[400px] custom-scrollbar">
                    <table class="min-w-full divide-y divide-gray-300">
                        <thead class="bg-slate-50 sticky top-0 z-10 shadow-sm">
                            <tr>
                                <th scope="col" class="py-4 pl-6 pr-3 text-left text-xs font-black text-slate-500 uppercase tracking-widest bg-slate-50 border-b border-slate-200">Pump Model</th>
                                <th scope="col" class="px-3 py-4 text-left text-xs font-black text-slate-500 uppercase tracking-widest bg-slate-50 border-b border-slate-200">Serial No.</th>
                                <th scope="col" class="px-3 py-4 text-left text-xs font-black text-slate-500 uppercase tracking-widest bg-slate-50 border-b border-slate-200">Impeller Dia</th>
                                <th scope="col" class="px-3 py-4 text-left text-xs font-black text-slate-500 uppercase tracking-widest bg-slate-50 border-b border-slate-200">Test Date</th>
                                <th scope="col" class="px-3 py-4 text-left text-xs font-black text-slate-500 uppercase tracking-widest bg-slate-50 border-b border-slate-200">Upload Time</th>
                                <th scope="col" class="relative py-4 pl-3 pr-6 text-right text-xs font-black text-slate-500 uppercase tracking-widest bg-slate-50 border-b border-slate-200">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="reportTableBody" class="divide-y divide-gray-200 bg-white">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Dropdown Toggle Logic
        const profileTrigger = document.getElementById('profileTrigger');
        const profileDropdown = document.getElementById('profileDropdown');

        profileTrigger.addEventListener('click', (e) => {
            e.stopPropagation();
            profileDropdown.classList.toggle('show');
        });

        // Close dropdown when clicking outside
        window.addEventListener('click', () => {
            if (profileDropdown.classList.contains('show')) {
                profileDropdown.classList.remove('show');
            }
        });

        const reportTableBody = document.getElementById('reportTableBody');
        const searchInput = document.getElementById('searchInput');
        const modelFilter = document.getElementById('modelFilter');
        const impellerFilter = document.getElementById('impellerFilter');
        const dateFilter = document.getElementById('dateFilter');
        const resultCount = document.getElementById('resultCount');

        // Access user role from EJS
        const currentUserRole = '<%= user.role %>';

        // Data from server
        const rawMongoData = <%- JSON.stringify(files || []) %>;

        const allReports = rawMongoData.map(item => {
            const td = item.trueData || {};
            const pd = td.pumpDetails || {};
            const dd = td.documentDetails || {};
            
            let testDateDisplay = '-';
            let testDateSort = '';
            if (dd.testDate) {
                const d = new Date(dd.testDate);
                testDateDisplay = d.toLocaleDateString('en-GB');
                testDateSort = d.toISOString().split('T')[0];
            }

            return {
                id: item._id,
                model: pd.model || 'Unknown',
                slNo: pd.serialNo || 'N/A',
                impeller: pd.impellerDiameterMm || '-',
                customer: dd.customerName || 'N/A',
                testDate: testDateDisplay,
                testDateValue: testDateSort,
                uploadedAt: item.createdAt ? new Date(item.createdAt).toLocaleString([], { dateStyle: 'short', timeStyle: 'short' }) : '-'
            };
        });

        function populateModelFilter() {
            const models = [...new Set(allReports.map(r => r.model))].sort();
            models.forEach(m => {
                const opt = document.createElement('option');
                opt.value = opt.textContent = m;
                modelFilter.appendChild(opt);
            });
        }

        function filterReports() {
            const s = searchInput.value.toLowerCase();
            const m = modelFilter.value;
            const i = impellerFilter.value;
            const d = dateFilter.value;

            const filtered = allReports.filter(r => {
                const matchSearch = !s || r.model.toLowerCase().includes(s) || r.slNo.toLowerCase().includes(s) || r.customer.toLowerCase().includes(s);
                const matchModel = !m || r.model === m;
                const matchImpeller = !i || String(r.impeller).includes(i);
                const matchDate = !d || r.testDateValue === d;
                return matchSearch && matchModel && matchImpeller && matchDate;
            });

            renderTable(filtered);
        }

        async function deleteReport(id, event) {
            event.stopPropagation(); // Prevent row click navigation
            
            if (!confirm("Are you sure you want to permanently delete this report and its files from S3? This action cannot be undone.")) {
                return;
            }

            try {
                const response = await fetch(`/delete-report/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const result = await response.json();
                if (result.success) {
                    alert("Report deleted successfully.");
                    window.location.reload();
                } else {
                    alert("Error: " + result.message);
                }
            } catch (err) {
                console.error(err);
                alert("Failed to delete report.");
            }
        }

        function renderTable(data) {
            reportTableBody.innerHTML = '';
            resultCount.textContent = `Displaying ${data.length} records`;

            if (data.length === 0) {
                reportTableBody.innerHTML = `<tr><td colspan="6" class="py-12 text-center text-slate-400 italic">No reports found matching your criteria.</td></tr>`;
                return;
            }

            data.forEach(r => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-blue-50/50 cursor-pointer transition-colors group";
                tr.onclick = () => window.location.href = `/report/${r.id}`;
                
                let actionHtml = `
                    <div class="flex items-center justify-end space-x-2">
                        <span class="inline-flex items-center px-3 py-1 bg-blue-50 text-blue-700 text-xs font-black uppercase rounded border border-blue-100 group-hover:bg-blue-600 group-hover:text-white transition-all">
                            View <i class="fa-solid fa-chevron-right ml-2"></i>
                        </span>
                `;

                if (currentUserRole === 'admin') {
                    actionHtml += `
                        <button onclick="deleteReport('${r.id}', event)" class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded transition-colors" title="Delete Report">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    `;
                }

                actionHtml += `</div>`;

                tr.innerHTML = `
                    <td class="whitespace-nowrap py-4 pl-6 pr-3 text-sm font-bold text-slate-900">${r.model}</td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm font-mono text-slate-500">${r.slNo}</td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600">${r.impeller} mm</td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600 font-medium">${r.testDate}</td>
                    <td class="whitespace-nowrap px-3 py-4 text-xs text-slate-400 italic">${r.uploadedAt}</td>
                    <td class="px-6 py-4 text-right">
                        ${actionHtml}
                    </td>
                `;
                reportTableBody.appendChild(tr);
            });
        }

        function resetFilters() {
            searchInput.value = '';
            modelFilter.value = '';
            impellerFilter.value = '';
            dateFilter.value = '';
            filterReports();
        }

        document.addEventListener('DOMContentLoaded', () => {
            populateModelFilter();
            filterReports();
        });
    </script>
</body>
</html>