<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Upload Design Data</title>
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Navbar with User Details -->
    <nav class="bg-white shadow-sm px-6 py-4 flex justify-between items-center">
        <div class="flex items-center space-x-4">
            <h1 class="text-xl font-bold text-blue-600">PumpSense Admin</h1>
        </div>
        
        <div class="flex items-center space-x-6">
            <!-- User Info Section -->
            <div class="hidden sm:flex items-center space-x-3 border-r pr-6 border-gray-200">
                <div class="text-right">
                    <p class="text-sm font-semibold text-gray-800"><%= user.username %></p>
                    <p class="text-xs text-gray-500 capitalize"><%= user.role %></p>
                </div>
                <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>
            </div>

            <div class="flex items-center space-x-4">
                <a href="/view-files" class="text-gray-600 hover:text-blue-600 font-medium transition">Reports</a>
                <a href="/logout" class="px-4 py-2 text-sm font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition">Logout</a>
            </div>
        </div>
    </nav>

    <div class="p-4 md:p-8">
        <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-md overflow-hidden">
            <div class="bg-blue-600 p-6 text-white">
                <div class="flex justify-between items-start">
                    <div>
                        <h2 class="text-2xl font-bold">New Pump Design Entry</h2>
                        <p class="text-blue-100 text-sm mt-1">Register master design specifications for performance comparison.</p>
                    </div>
                    <div class="bg-blue-500 px-3 py-1 rounded text-xs font-mono">
                        ADMIN_MODE
                    </div>
                </div>
            </div>

            <% if (message && message.length > 0) { %>
                <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 m-6 rounded-r" role="alert">
                    <div class="flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                        </svg>
                        <p class="font-bold">Error</p>
                    </div>
                    <p class="text-sm mt-1 ml-7"><%= message %></p>
                </div>
            <% } %>

            <form action="/upload-design" method="POST" class="p-6 space-y-6">
                <!-- Row 1: Identification -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Pump Model</label>
                        <input type="text" name="pumpModel" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                            placeholder="e.g. CentriFlow-X500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Serial No.</label>
                        <input type="text" name="serialNo" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                            placeholder="e.g. SN-2023-089">
                    </div>
                </div>

                <hr class="border-gray-100">

                <!-- Row 2: Metrics -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Discharge (m³/hr)</label>
                        <input type="number" step="0.01" name="discharge" min="0" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Power (Kw)</label>
                        <input type="number" step="0.01" name="power" min="0" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Efficiency (%)</label>
                        <input type="number" step="0.1" name="efficiency" min="0" max="100" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Total Head (MWC)</label>
                        <input type="number" step="0.01" name="totalHead" min="0" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition">
                    </div>
                </div>

                <div class="pt-4 flex flex-col md:flex-row gap-4">
                    <button type="submit" 
                        class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg shadow-lg transition-all active:scale-95">
                        Save Design Specification
                    </button>
                    <a href="/view-files" class="px-6 py-3 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition text-center font-medium">
                        Back to Dashboard
                    </a>
                </div>
            </form>
        </div>
        
        <p class="text-center text-gray-400 text-xs mt-8">
            &copy; 2024 PumpSense Engineering Systems. All rights reserved.
        </p>
    </div>
</body>
</html>