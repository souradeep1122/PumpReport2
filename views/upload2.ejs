<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PUMPSENSE | Upload Certificates</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
        .drag-active { border-color: #3b82f6 !important; background-color: #eff6ff !important; }
        .dropdown-menu { display: none; opacity: 0; transform: translateY(-10px); transition: opacity 0.2s ease, transform 0.2s ease; }
        .dropdown-menu.show { display: block; opacity: 1; transform: translateY(0); }
        .pulse-blue { animation: pulse-blue 2s infinite; }
        @keyframes pulse-blue { 0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); } 70% { box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); } 100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); } }
        .fade-in { animation: fadeIn 0.3s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <header class="bg-white shadow-sm sticky top-0 z-50 px-6 py-3">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 flex items-center justify-center">
                    <img src="https://undertaker099.s3.ap-south-1.amazonaws.com/NodeJs_Excel_Uploads/logo+(1).png" alt="Pumpsense Logo" class="h-full w-auto object-contain block">
                </div>
                <div class="border-l border-gray-200 pl-4">
                    <h1 class="text-xl font-bold tracking-tight text-slate-900 uppercase leading-none">Pumpsense</h1>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Fluid Engineering</p>
                </div>                                         
            </div>

            <div class="flex items-center space-x-6">
                <nav class="hidden md:flex items-center space-x-6 mr-4">
                    <a href="/view-files" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">
                        <i class="fa-solid fa-table-list mr-1"></i> Performance Reports
                    </a>
                </nav>

                <div class="relative">
                    <button id="profileTrigger" class="focus:outline-none transition-transform hover:scale-105 active:scale-95">
                        <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold shadow-md border-2 border-white">
                            A
                        </div>
                    </button>
                    <div id="profileDropdown" class="dropdown-menu absolute right-0 mt-3 w-56 bg-white rounded-xl shadow-2xl border border-gray-100 z-50 overflow-hidden">
                        <div class="p-4 bg-gray-50/50 border-b border-gray-100 text-center">
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Signed in as</p>
                            <p class="text-sm font-bold text-slate-900 truncate">Admin User</p>
                        </div>
                        <div class="p-2">
                            <a href="/logout" class="flex items-center gap-3 px-3 py-3 rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                                <i class="fa-solid fa-right-from-bracket w-4"></i>
                                <span class="text-sm font-bold">Logout</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow flex flex-col items-center justify-center p-4">
        
        <!-- Automation Banner -->
        <div class="w-full max-w-4xl mb-6">
            <div class="bg-white rounded-2xl shadow-sm border border-blue-100 p-4 flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div id="autoStatusIcon" class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center transition-colors">
                        <i class="fa-solid fa-robot text-xl"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-800 text-sm">Automation Mode</h3>
                        <p id="autoStatusText" class="text-xs text-slate-500">Automatically fetch and upload new files from a specific folder.</p>
                    </div>
                </div>
                <button id="enableAutoBtn" class="px-6 py-2 bg-blue-600 text-white text-xs font-bold rounded-xl hover:bg-blue-700 transition-all shadow-md flex items-center gap-2">
                    <i class="fa-solid fa-folder-open"></i>
                    <span>Enable Folder Watcher</span>
                </button>
            </div>
        </div>

        <div class="bg-white w-full max-w-4xl rounded-2xl shadow-xl overflow-hidden">
            <div class="bg-blue-600 p-8 text-white text-center">
                <div class="mb-4">
                    <i class="fa-solid fa-file-circle-check text-5xl opacity-90"></i>
                </div>
                <h1 class="text-2xl font-bold">File Comparison Upload</h1>
                <p class="text-blue-100 text-sm mt-2">Upload the original certificate to process performance data.</p>
            </div>

            <div class="p-8">
                <form action="/upload" method="post" enctype="multipart/form-data" id="uploadForm">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        
                        <!-- Section 1: True File -->
                        <div>
                            <h2 class="text-gray-700 font-bold mb-3 flex items-center">
                                <span class="bg-blue-100 text-blue-600 w-6 h-6 rounded-full flex items-center justify-center text-xs mr-2">1</span>
                                True / Original File <span class="text-red-500 ml-1">*</span>
                            </h2>
                            
                            <div id="dropZone1" class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center transition-all duration-300 cursor-pointer hover:border-blue-400 hover:bg-gray-50 group h-64 flex flex-col justify-center relative">
                                <input accept=".xls,.xlsx" type="file" name="file" id="fileInput1" class="hidden" />
                                
                                <div id="emptyState1">
                                    <div class="w-14 h-14 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform">
                                        <i class="fa-solid fa-cloud-arrow-up text-xl"></i>
                                    </div>
                                    <h3 class="text-gray-800 font-semibold text-base">Upload True File</h3>
                                    <p class="text-xs text-gray-400 mt-2">Mandatory: .xls, .xlsx</p>
                                </div>

                                <div id="loadingState1" class="hidden absolute inset-0 bg-white bg-opacity-90 flex flex-col items-center justify-center z-10 rounded-xl">
                                    <div class="w-12 h-12 bg-gray-100 text-blue-500 rounded-full flex items-center justify-center mb-3 animate-pulse">
                                        <i class="fa-solid fa-spinner fa-spin text-xl"></i>
                                    </div>
                                    <p class="text-gray-600 text-sm font-medium">Validating Content...</p>
                                </div>

                                <div id="fileState1" class="hidden absolute inset-0 bg-white flex flex-col items-center justify-center z-10 rounded-xl">
                                    <div class="w-14 h-14 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-3">
                                        <i class="fa-solid fa-file-excel text-xl"></i>
                                    </div>
                                    <p id="fileName1" class="text-gray-800 font-semibold text-sm break-all px-4">filename.xlsx</p>
                                    <span class="mt-2 bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full font-medium"><i class="fa-solid fa-check mr-1"></i>Verified</span>
                                    <button type="button" id="removeFileBtn1" class="text-red-500 text-xs hover:underline mt-3">Remove</button>
                                </div>
                            </div>
                        </div>

                        <!-- Section 2: Altered File -->
                        <div>
                            <h2 class="text-gray-700 font-bold mb-3 flex items-center">
                                <span class="bg-purple-100 text-purple-600 w-6 h-6 rounded-full flex items-center justify-center text-xs mr-2">2</span>
                                Altered File <span class="text-gray-400 text-[10px] ml-2 font-normal">(Optional)</span>
                            </h2>

                            <div id="dropZone2" class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center transition-all duration-300 cursor-pointer hover:border-purple-400 hover:bg-purple-50 group h-64 flex flex-col justify-center relative">
                                <input accept=".xls,.xlsx" type="file" name="file" id="fileInput2" class="hidden" />
                                
                                <div id="emptyState2">
                                    <div class="w-14 h-14 bg-purple-50 text-purple-500 rounded-full flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform">
                                        <i class="fa-solid fa-cloud-arrow-up text-xl"></i>
                                    </div>
                                    <h3 class="text-gray-800 font-semibold text-base">Upload Altered File</h3>
                                    <p class="text-xs text-gray-400 mt-2">Optional: .xls, .xlsx</p>
                                </div>

                                <div id="loadingState2" class="hidden absolute inset-0 bg-white bg-opacity-90 flex flex-col items-center justify-center z-10 rounded-xl">
                                    <div class="w-12 h-12 bg-gray-100 text-purple-500 rounded-full flex items-center justify-center mb-3 animate-pulse">
                                        <i class="fa-solid fa-spinner fa-spin text-xl"></i>
                                    </div>
                                    <p class="text-gray-600 text-sm font-medium">Validating Content...</p>
                                </div>

                                <div id="fileState2" class="hidden absolute inset-0 bg-white flex flex-col items-center justify-center z-10 rounded-xl">
                                    <div class="w-14 h-14 bg-purple-100 text-purple-600 rounded-full flex items-center justify-center mb-3">
                                        <i class="fa-solid fa-file-excel text-xl"></i>
                                    </div>
                                    <p id="fileName2" class="text-gray-800 font-semibold text-sm break-all px-4">filename.xlsx</p>
                                    <span class="mt-2 bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full font-medium"><i class="fa-solid fa-check mr-1"></i>Verified</span>
                                    <button type="button" id="removeFileBtn2" class="text-red-500 text-xs hover:underline mt-3">Remove</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" id="submitBtn" class="w-full mt-8 bg-gray-300 text-gray-500 font-semibold py-4 px-4 rounded-xl shadow-sm cursor-not-allowed transition-all duration-300" disabled>
                        Process Comparison
                    </button>
                </form>
            </div>
        </div>
    </main>

    <script>
        const profileTrigger = document.getElementById('profileTrigger');
        const profileDropdown = document.getElementById('profileDropdown');
        profileTrigger.addEventListener('click', (e) => { e.stopPropagation(); profileDropdown.classList.toggle('show'); });
        window.addEventListener('click', () => profileDropdown.classList.remove('show'));

        const requiredMarkers = ["pump performance test certificate", "pump model", "motor make"];
        const fileStatus = { file1: false, file2: false };
        const submitBtn = document.getElementById('submitBtn');
        const uploadForm = document.getElementById('uploadForm');

        // Automation Variables
        const enableAutoBtn = document.getElementById('enableAutoBtn');
        const autoStatusText = document.getElementById('autoStatusText');
        const autoStatusIcon = document.getElementById('autoStatusIcon');
        let directoryHandle = null;
        let knownFiles = new Set();
        let watchInterval = null;

        function updateSubmitButton() {
            if (fileStatus.file1) {
                submitBtn.disabled = false;
                submitBtn.className = "w-full mt-8 bg-blue-600 text-white font-semibold py-4 px-4 rounded-xl shadow-md hover:bg-blue-700 transition-all cursor-pointer flex items-center justify-center";
                submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane mr-2"></i> Process Comparison';
            } else {
                submitBtn.disabled = true;
                submitBtn.className = "w-full mt-8 bg-gray-300 text-gray-500 font-semibold py-4 px-4 rounded-xl shadow-sm cursor-not-allowed transition-all";
                submitBtn.innerHTML = 'Process Comparison';
            }
        }

        function setupUploadZone(zoneIndex) {
            const dropZone = document.getElementById(`dropZone${zoneIndex}`);
            const fileInput = document.getElementById(`fileInput${zoneIndex}`);
            const emptyState = document.getElementById(`emptyState${zoneIndex}`);
            const loadingState = document.getElementById(`loadingState${zoneIndex}`);
            const fileState = document.getElementById(`fileState${zoneIndex}`);
            const fileNameDisplay = document.getElementById(`fileName${zoneIndex}`);
            const removeFileBtn = document.getElementById(`removeFileBtn${zoneIndex}`);

            dropZone.addEventListener('click', (e) => {
                if (e.target !== removeFileBtn && !fileStatus[`file${zoneIndex}`]) fileInput.click();
            });

            fileInput.addEventListener('change', function() { handleFiles(this.files); });

            // Global access for Automation logic
            window[`triggerUpload${zoneIndex}`] = (file) => handleFiles([file]);

            function handleFiles(files) {
                if (files.length > 0) {
                    const file = files[0];
                    if (!file.name.match(/\.(xls|xlsx)$/)) {
                        alert('Invalid format. Please use .xls or .xlsx');
                        return;
                    }
                    loadingState.classList.remove('hidden');
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        try {
                            const data = new Uint8Array(e.target.result);
                            const workbook = XLSX.read(data, {type: 'array'});
                            let fullText = "";
                            workbook.SheetNames.forEach(sn => {
                                const ws = workbook.Sheets[sn];
                                const json = XLSX.utils.sheet_to_json(ws, {header: 1});
                                fullText += " " + json.map(r => r.join(" ")).join(" ");
                            });
                            fullText = fullText.toLowerCase();
                            const missing = requiredMarkers.filter(m => !fullText.includes(m.toLowerCase()));
                            
                            setTimeout(() => {
                                if (missing.length === 0) {
                                    loadingState.classList.add('hidden');
                                    emptyState.classList.add('hidden');
                                    fileState.classList.remove('hidden');
                                    fileNameDisplay.textContent = file.name;
                                    fileStatus[`file${zoneIndex}`] = true;
                                    
                                    const dT = new DataTransfer();
                                    dT.items.add(file);
                                    fileInput.files = dT.files;
                                    updateSubmitButton();

                                    // --- AUTO SUBMISSION TRIGGER ---
                                    if (directoryHandle && zoneIndex === 1) {
                                        showToast(`Verified: ${file.name}. Auto-uploading...`);
                                        submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Auto-submitting...';
                                        submitBtn.disabled = true;
                                        
                                        // Brief delay so user can see the "Verified" status before redirect
                                        setTimeout(() => {
                                            uploadForm.submit();
                                        }, 1200);
                                    }
                                } else {
                                    alert(`Invalid content. File "${file.name}" is missing markers: ${missing.join(', ')}`);
                                    resetZone();
                                }
                            }, 500);
                        } catch (err) { alert("Error reading file."); resetZone(); }
                    };
                    reader.readAsArrayBuffer(file);
                }
            }

            function resetZone() {
                fileInput.value = '';
                loadingState.classList.add('hidden');
                fileState.classList.add('hidden');
                emptyState.classList.remove('hidden');
                fileStatus[`file${zoneIndex}`] = false;
                updateSubmitButton();
            }

            removeFileBtn.addEventListener('click', (e) => { e.stopPropagation(); resetZone(); });
        }

        // --- Automation Logic ---
        enableAutoBtn.addEventListener('click', async () => {
            if (watchInterval) {
                stopWatcher();
                return;
            }

            try {
                // Request directory permission
                directoryHandle = await window.showDirectoryPicker();
                
                // Change UI state
                enableAutoBtn.innerHTML = '<i class="fa-solid fa-stop-circle"></i> Stop Watcher';
                enableAutoBtn.classList.replace('bg-blue-600', 'bg-red-500');
                autoStatusIcon.classList.replace('bg-blue-50', 'bg-blue-100');
                autoStatusIcon.classList.add('pulse-blue', 'text-blue-500');
                autoStatusText.innerHTML = `Watching: <span class="font-bold text-blue-600">${directoryHandle.name}</span> (Auto-upload enabled)`;

                // Initial scan - remember current files so we only upload NEW ones
                knownFiles.clear();
                for await (const entry of directoryHandle.values()) {
                    if (entry.kind === 'file' && entry.name.match(/\.(xls|xlsx)$/)) {
                        knownFiles.add(entry.name);
                    }
                }

                // Start Polling (every 3 seconds)
                watchInterval = setInterval(watchFolder, 3000);
                showToast("Folder watcher active. Drop a new report to auto-upload.");

            } catch (err) {
                console.error("Directory access denied or cancelled", err);
            }
        });

        function stopWatcher() {
            clearInterval(watchInterval);
            watchInterval = null;
            directoryHandle = null;
            enableAutoBtn.innerHTML = '<i class="fa-solid fa-folder-open"></i> Enable Folder Watcher';
            enableAutoBtn.classList.replace('bg-red-500', 'bg-blue-600');
            autoStatusIcon.classList.remove('pulse-blue', 'text-blue-500');
            autoStatusIcon.classList.replace('bg-blue-100', 'bg-blue-50');
            autoStatusText.innerHTML = `Automation Mode stopped.`;
        }

        async function watchFolder() {
            if (!directoryHandle) return;

            try {
                for await (const entry of directoryHandle.values()) {
                    if (entry.kind === 'file' && entry.name.match(/\.(xls|xlsx)$/)) {
                        if (!knownFiles.has(entry.name)) {
                            knownFiles.add(entry.name);

                            // Fetch the file object
                            const file = await entry.getFile();
                            
                            // Automatically populate Zone 1 (True File) and trigger the auto-submit logic inside handleFiles
                            window.triggerUpload1(file);
                        }
                    }
                }
            } catch (e) {
                console.error("Watcher polling error:", e);
                stopWatcher();
                alert("Folder access lost. Please re-enable the watcher.");
            }
        }

        function showToast(msg) {
            const toast = document.createElement('div');
            toast.className = "fixed bottom-5 right-5 bg-slate-800 text-white px-6 py-3 rounded-xl shadow-2xl text-sm font-medium z-[100] fade-in flex items-center gap-3 border-l-4 border-blue-400";
            toast.innerHTML = `<i class="fa-solid fa-bolt text-blue-400 animate-pulse"></i> ${msg}`;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(10px)';
                toast.style.transition = 'all 0.5s ease';
                setTimeout(() => toast.remove(), 500);
            }, 4000);
        }

        setupUploadZone(1);
        setupUploadZone(2);
    </script>
</body>
</html>