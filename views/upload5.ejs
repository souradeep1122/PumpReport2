<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PUMPSENSE | Upload Certificates</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
        .drag-active { border-color: #3b82f6 !important; background-color: #eff6ff !important; }
        .dropdown-menu { display: none; opacity: 0; transform: translateY(-10px); transition: opacity 0.2s ease, transform 0.2s ease; }
        .dropdown-menu.show { display: block; opacity: 1; transform: translateY(0); }
        .pulse-blue { animation: pulse-blue 2s infinite; }
        @keyframes pulse-blue { 0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); } 70% { box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); } 100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); } }
        .fade-in { animation: fadeIn 0.3s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Mode Toggle Styles */
        .mode-toggle {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .active-mode-manual { border-color: #64748b; background-color: #f8fafc; }
        .active-mode-auto { border-color: #3b82f6; background-color: #eff6ff; }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <header class="bg-white shadow-sm sticky top-0 z-50 px-6 py-3">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 flex items-center justify-center">
                    <img src="https://undertaker099.s3.ap-south-1.amazonaws.com/NodeJs_Excel_Uploads/logo+(1).png" alt="Pumpsense Logo" class="h-full w-auto object-contain block">
                </div>
                <div class="border-l border-gray-200 pl-4">
                    <h1 class="text-xl font-bold tracking-tight text-slate-900 uppercase leading-none">Pumpsense</h1>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Fluid Engineering</p>
                </div>                                         
            </div>

            <div class="flex items-center space-x-6">
                <nav class="hidden md:flex items-center space-x-6 mr-4">
                    <a href="/view-files" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">
                        <i class="fa-solid fa-table-list mr-1"></i> Performance Reports
                    </a>
                </nav>

                <div class="relative">
                    <button id="profileTrigger" class="focus:outline-none transition-transform hover:scale-105 active:scale-95">
                        <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold shadow-md border-2 border-white">
                            A
                        </div>
                    </button>
                    <div id="profileDropdown" class="dropdown-menu absolute right-0 mt-3 w-56 bg-white rounded-xl shadow-2xl border border-gray-100 z-50 overflow-hidden">
                        <div class="p-4 bg-gray-50/50 border-b border-gray-100 text-center">
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Signed in as</p>
                            <p class="text-sm font-bold text-slate-900 truncate">Admin User</p>
                        </div>
                        <div class="p-2">
                            <a href="/logout" class="flex items-center gap-3 px-3 py-3 rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                                <i class="fa-solid fa-right-from-bracket w-4"></i>
                                <span class="text-sm font-bold">Logout</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow flex flex-col items-center justify-center p-4">
        
        <!-- Mode Switcher Banner -->
        <div class="w-full max-w-4xl mb-6">
            <div id="modeBanner" class="bg-white rounded-2xl shadow-sm border p-4 flex flex-col md:flex-row items-center justify-between gap-4 mode-toggle active-mode-manual">
                <div class="flex items-center gap-4">
                    <div id="modeIcon" class="w-12 h-12 bg-slate-100 text-slate-600 rounded-full flex items-center justify-center transition-all">
                        <i class="fa-solid fa-hand-pointer text-xl"></i>
                    </div>
                    <div>
                        <h3 id="modeTitle" class="font-bold text-slate-800 text-sm">Manual Upload Mode</h3>
                        <p id="modeDescription" class="text-xs text-slate-500">Upload certificates manually for comparison.</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 bg-slate-100 p-1.5 rounded-xl border border-slate-200">
                    <button id="btnManualMode" class="px-4 py-1.5 rounded-lg text-xs font-bold transition-all bg-white shadow-sm text-slate-800">Manual</button>
                    <button id="btnAutoMode" class="px-4 py-1.5 rounded-lg text-xs font-bold transition-all text-slate-400 hover:text-slate-600">Automatic</button>
                </div>
                
                <!-- Automation Specific Controls (Hidden by default) -->
                <div id="autoControls" class="hidden flex gap-2 border-l border-slate-200 pl-4">
                    <button id="enableAutoBtn" class="px-5 py-2 bg-blue-600 text-white text-xs font-bold rounded-xl hover:bg-blue-700 transition-all shadow-md flex items-center gap-2">
                        <i class="fa-solid fa-play"></i>
                        <span>Start Sync</span>
                    </button>
                    <button id="changeFolderBtn" class="px-3 py-2 bg-white text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-50 transition-all border border-slate-200">
                        <i class="fa-solid fa-folder-gear"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="bg-white w-full max-w-4xl rounded-2xl shadow-xl overflow-hidden">
            <div id="mainHeader" class="bg-slate-700 p-8 text-white text-center transition-colors duration-500">
                <div class="mb-4">
                    <i id="headerIcon" class="fa-solid fa-file-import text-5xl opacity-90"></i>
                </div>
                <h1 class="text-2xl font-bold">Process Performance Reports</h1>
                <p id="headerSubtext" class="text-slate-200 text-sm mt-2">Manual entry mode enabled.</p>
            </div>

            <div class="p-8">
                <form id="uploadForm" action="/upload" method="post" enctype="multipart/form-data">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        
                        <!-- Section 1: True File -->
                        <div>
                            <h2 class="text-gray-700 font-bold mb-3 flex items-center">
                                <span class="bg-blue-100 text-blue-600 w-6 h-6 rounded-full flex items-center justify-center text-xs mr-2">1</span>
                                True / Original File <span class="text-red-500 ml-1">*</span>
                            </h2>
                            
                            <div id="dropZone1" class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center transition-all duration-300 cursor-pointer hover:border-blue-400 hover:bg-gray-50 group h-64 flex flex-col justify-center relative">
                                <input accept=".xls,.xlsx" type="file" name="file" id="fileInput1" class="hidden" />
                                
                                <div id="emptyState1">
                                    <div class="w-14 h-14 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform">
                                        <i class="fa-solid fa-cloud-arrow-up text-xl"></i>
                                    </div>
                                    <h3 class="text-gray-800 font-semibold text-base">Upload Original</h3>
                                    <p class="text-xs text-gray-400 mt-2">Mandatory: .xls, .xlsx</p>
                                </div>

                                <div id="loadingState1" class="hidden absolute inset-0 bg-white bg-opacity-90 flex flex-col items-center justify-center z-10 rounded-xl">
                                    <div class="w-12 h-12 bg-gray-100 text-blue-500 rounded-full flex items-center justify-center mb-3 animate-pulse">
                                        <i class="fa-solid fa-spinner fa-spin text-xl"></i>
                                    </div>
                                    <p class="text-gray-600 text-sm font-medium">Processing...</p>
                                </div>

                                <div id="fileState1" class="hidden absolute inset-0 bg-white flex flex-col items-center justify-center z-10 rounded-xl">
                                    <div class="w-14 h-14 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-3">
                                        <i class="fa-solid fa-file-excel text-xl"></i>
                                    </div>
                                    <p id="fileName1" class="text-gray-800 font-semibold text-sm break-all px-4">filename.xlsx</p>
                                    <span class="mt-2 bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full font-medium"><i class="fa-solid fa-check mr-1"></i>Verified</span>
                                    <button type="button" id="removeFileBtn1" class="text-red-500 text-xs hover:underline mt-3">Remove</button>
                                </div>
                            </div>
                        </div>

                        <!-- Section 2: Altered File -->
                        <div>
                            <h2 class="text-gray-700 font-bold mb-3 flex items-center">
                                <span class="bg-purple-100 text-purple-600 w-6 h-6 rounded-full flex items-center justify-center text-xs mr-2">2</span>
                                Altered File <span class="text-gray-400 text-[10px] ml-2 font-normal">(Optional)</span>
                            </h2>

                            <div id="dropZone2" class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center transition-all duration-300 cursor-pointer hover:border-purple-400 hover:bg-gray-50 group h-64 flex flex-col justify-center relative">
                                <input accept=".xls,.xlsx" type="file" name="file" id="fileInput2" class="hidden" />
                                
                                <div id="emptyState2">
                                    <div class="w-14 h-14 bg-purple-50 text-purple-500 rounded-full flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform">
                                        <i class="fa-solid fa-file-circle-plus text-xl"></i>
                                    </div>
                                    <h3 class="text-gray-800 font-semibold text-base">Upload Altered</h3>
                                    <p class="text-xs text-gray-400 mt-2">Compare against original</p>
                                </div>

                                <div id="loadingState2" class="hidden absolute inset-0 bg-white bg-opacity-90 flex flex-col items-center justify-center z-10 rounded-xl">
                                    <div class="w-12 h-12 bg-gray-100 text-purple-500 rounded-full flex items-center justify-center mb-3 animate-pulse">
                                        <i class="fa-solid fa-spinner fa-spin text-xl"></i>
                                    </div>
                                    <p class="text-gray-600 text-sm font-medium">Processing...</p>
                                </div>

                                <div id="fileState2" class="hidden absolute inset-0 bg-white flex flex-col items-center justify-center z-10 rounded-xl">
                                    <div class="w-14 h-14 bg-purple-100 text-purple-600 rounded-full flex items-center justify-center mb-3">
                                        <i class="fa-solid fa-file-shield text-xl"></i>
                                    </div>
                                    <p id="fileName2" class="text-gray-800 font-semibold text-sm break-all px-4">filename.xlsx</p>
                                    <span class="mt-2 bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full font-medium"><i class="fa-solid fa-check mr-1"></i>Verified</span>
                                    <button type="button" id="removeFileBtn2" class="text-red-500 text-xs hover:underline mt-3">Remove</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" id="submitBtn" class="w-full mt-8 bg-gray-300 text-gray-500 font-semibold py-4 px-4 rounded-xl shadow-sm cursor-not-allowed transition-all duration-300" disabled>
                        Process Comparison
                    </button>
                </form>
            </div>
        </div>
    </main>

    <script>
        // UI & State
        const profileTrigger = document.getElementById('profileTrigger');
        const profileDropdown = document.getElementById('profileDropdown');
        const uploadForm = document.getElementById('uploadForm');
        const submitBtn = document.getElementById('submitBtn');
        const requiredMarkers = ["pump performance test certificate", "pump model", "motor make"];
        
        let currentMode = 'manual'; // 'manual' or 'auto'
        let fileStatus = { file1: false, file2: false };
        let isUploading = false;

        profileTrigger.addEventListener('click', (e) => { e.stopPropagation(); profileDropdown.classList.toggle('show'); });
        window.addEventListener('click', () => profileDropdown.classList.remove('show'));

        // --- Mode Switching ---
        const btnManualMode = document.getElementById('btnManualMode');
        const btnAutoMode = document.getElementById('btnAutoMode');
        const modeBanner = document.getElementById('modeBanner');
        const modeIcon = document.getElementById('modeIcon');
        const modeTitle = document.getElementById('modeTitle');
        const modeDescription = document.getElementById('modeDescription');
        const autoControls = document.getElementById('autoControls');
        const mainHeader = document.getElementById('mainHeader');
        const headerIcon = document.getElementById('headerIcon');

        function setMode(mode) {
            currentMode = mode;
            if (mode === 'manual') {
                stopWatcher();
                btnManualMode.className = "px-4 py-1.5 rounded-lg text-xs font-bold transition-all bg-white shadow-sm text-slate-800";
                btnAutoMode.className = "px-4 py-1.5 rounded-lg text-xs font-bold transition-all text-slate-400 hover:text-slate-600";
                modeBanner.className = "bg-white rounded-2xl shadow-sm border p-4 flex flex-col md:flex-row items-center justify-between gap-4 mode-toggle active-mode-manual";
                modeIcon.innerHTML = '<i class="fa-solid fa-hand-pointer text-xl"></i>';
                modeTitle.innerText = "Manual Upload Mode";
                modeDescription.innerText = "Upload certificates manually for comparison.";
                autoControls.classList.add('hidden');
                mainHeader.className = "bg-slate-700 p-8 text-white text-center transition-all duration-500";
                headerIcon.className = "fa-solid fa-file-import text-5xl opacity-90";
                document.getElementById('headerSubtext').innerText = "Manual entry mode enabled.";
            } else {
                btnAutoMode.className = "px-4 py-1.5 rounded-lg text-xs font-bold transition-all bg-white shadow-sm text-blue-600";
                btnManualMode.className = "px-4 py-1.5 rounded-lg text-xs font-bold transition-all text-slate-400 hover:text-slate-600";
                modeBanner.className = "bg-white rounded-2xl shadow-sm border p-4 flex flex-col md:flex-row items-center justify-between gap-4 mode-toggle active-mode-auto";
                modeIcon.innerHTML = '<i class="fa-solid fa-robot text-xl"></i>';
                modeTitle.innerText = "Automatic Device Sync";
                modeDescription.innerText = "Watching device export folder for new reports.";
                autoControls.classList.remove('hidden');
                mainHeader.className = "bg-blue-600 p-8 text-white text-center transition-all duration-500";
                headerIcon.className = "fa-solid fa-bolt text-5xl opacity-90";
                document.getElementById('headerSubtext').innerText = "Real-time sync mode enabled.";
            }
            updateSubmitButton();
        }

        btnManualMode.addEventListener('click', () => setMode('manual'));
        btnAutoMode.addEventListener('click', () => setMode('auto'));

        // --- Core Logic ---

        async function performAsyncUpload() {
            if (isUploading) return;
            isUploading = true;

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Uploading Data...';

            const formData = new FormData(uploadForm);
            
            try {
                const response = await fetch(uploadForm.action, {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    showToast("Sync Successful: Data processed.", "fa-circle-check");
                    resetZone(1);
                    resetZone(2);
                } else {
                    showToast("Upload Error: Server rejected the file.", "fa-circle-xmark");
                }
            } catch (error) {
                showToast("Connection Error: Check server status.", "fa-wifi");
            } finally {
                isUploading = false;
                updateSubmitButton();
            }
        }

        uploadForm.addEventListener('submit', (e) => {
            e.preventDefault();
            performAsyncUpload();
        });

        function updateSubmitButton() {
            if (fileStatus.file1) {
                submitBtn.disabled = false;
                submitBtn.className = "w-full mt-8 bg-blue-600 text-white font-semibold py-4 px-4 rounded-xl shadow-md hover:bg-blue-700 transition-all cursor-pointer flex items-center justify-center";
                submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane mr-2"></i> Process Comparison';
            } else {
                submitBtn.disabled = true;
                submitBtn.className = "w-full mt-8 bg-gray-300 text-gray-500 font-semibold py-4 px-4 rounded-xl shadow-sm cursor-not-allowed transition-all";
                submitBtn.innerHTML = 'Process Comparison';
            }
        }

        function setupUploadZone(idx) {
            const dropZone = document.getElementById(`dropZone${idx}`);
            const fileInput = document.getElementById(`fileInput${idx}`);
            const removeFileBtn = document.getElementById(`removeFileBtn${idx}`);

            dropZone.addEventListener('click', (e) => {
                if (e.target !== removeFileBtn && !fileStatus[`file${idx}`]) fileInput.click();
            });

            fileInput.addEventListener('change', function() { handleFiles(this.files, idx); });

            async function handleFiles(files, zoneIdx) {
                if (files.length === 0) return;
                const file = files[0];
                if (!file.name.match(/\.(xls|xlsx)$/)) return;

                const loadingState = document.getElementById(`loadingState${zoneIdx}`);
                loadingState.classList.remove('hidden');

                const reader = new FileReader();
                reader.onload = async function(e) {
                    try {
                        const data = new Uint8Array(e.target.result);
                        const workbook = XLSX.read(data, {type: 'array'});
                        let fullText = "";
                        workbook.SheetNames.forEach(sn => {
                            const ws = workbook.Sheets[sn];
                            const json = XLSX.utils.sheet_to_json(ws, {header: 1});
                            fullText += " " + json.map(r => r.join(" ")).join(" ");
                        });
                        fullText = fullText.toLowerCase();
                        const missing = requiredMarkers.filter(m => !fullText.includes(m.toLowerCase()));

                        if (missing.length === 0) {
                            document.getElementById(`loadingState${zoneIdx}`).classList.add('hidden');
                            document.getElementById(`emptyState${zoneIdx}`).classList.add('hidden');
                            document.getElementById(`fileState${zoneIdx}`).classList.remove('hidden');
                            document.getElementById(`fileName${zoneIdx}`).textContent = file.name;
                            fileStatus[`file${zoneIdx}`] = true;

                            const dT = new DataTransfer();
                            dT.items.add(file);
                            fileInput.files = dT.files;
                            updateSubmitButton();

                            // Auto-upload ONLY in Auto Mode and ONLY for Original File (Zone 1)
                            if (currentMode === 'auto' && zoneIdx === 1 && directoryHandle) {
                                performAsyncUpload();
                            }
                        } else {
                            showToast(`Missing required markers: ${missing.join(', ')}`, "fa-triangle-exclamation");
                            resetZone(zoneIdx);
                        }
                    } catch (err) { resetZone(zoneIdx); }
                };
                reader.readAsArrayBuffer(file);
            }
        }

        window.resetZone = (idx) => {
            const fInput = document.getElementById(`fileInput${idx}`);
            const lState = document.getElementById(`loadingState${idx}`);
            const fState = document.getElementById(`fileState${idx}`);
            const eState = document.getElementById(`emptyState${idx}`);
            if (fInput) fInput.value = '';
            if (lState) lState.classList.add('hidden');
            if (fState) fState.classList.add('hidden');
            if (eState) eState.classList.remove('hidden');
            fileStatus[`file${idx}`] = false;
            updateSubmitButton();
        };

        document.getElementById('removeFileBtn1').addEventListener('click', (e) => { e.stopPropagation(); resetZone(1); });
        document.getElementById('removeFileBtn2').addEventListener('click', (e) => { e.stopPropagation(); resetZone(2); });

        // --- Automation Logic (Sync Only) ---
        const enableAutoBtn = document.getElementById('enableAutoBtn');
        const changeFolderBtn = document.getElementById('changeFolderBtn');
        let directoryHandle = null;
        let knownFiles = new Set();
        let watchInterval = null;

        async function openDB() {
            return new Promise((res, rej) => {
                const req = indexedDB.open('PumpsenseSync', 1);
                req.onupgradeneeded = () => req.result.createObjectStore('settings');
                req.onsuccess = () => res(req.result);
                req.onerror = () => rej(req.error);
            });
        }

        async function getStoredHandle() {
            try {
                const db = await openDB();
                return new Promise(res => {
                    const req = db.transaction('settings').objectStore('settings').get('folderHandle');
                    req.onsuccess = () => res(req.result);
                    req.onerror = () => res(null);
                });
            } catch(e) { return null; }
        }

        async function storeHandle(handle) {
            const db = await openDB();
            db.transaction('settings', 'readwrite').objectStore('settings').put(handle, 'folderHandle');
        }

        async function startWatching() {
            if (watchInterval) { stopWatcher(); return; }
            try {
                directoryHandle = await getStoredHandle();
                if (!directoryHandle) {
                    directoryHandle = await window.showDirectoryPicker();
                    await storeHandle(directoryHandle);
                } else {
                    if ((await directoryHandle.requestPermission({mode: 'read'})) !== 'granted') return;
                }
                enableAutoBtn.innerHTML = '<i class="fa-solid fa-stop"></i> Stop Sync';
                enableAutoBtn.classList.replace('bg-blue-600', 'bg-red-500');
                knownFiles.clear();
                for await (const entry of directoryHandle.values()) {
                    if (entry.kind === 'file' && entry.name.match(/\.(xls|xlsx)$/)) knownFiles.add(entry.name);
                }
                watchInterval = setInterval(watchFolder, 3000);
                showToast("Folder synchronization active.");
            } catch (err) { stopWatcher(); }
        }

        function stopWatcher() {
            clearInterval(watchInterval); watchInterval = null;
            enableAutoBtn.innerHTML = '<i class="fa-solid fa-play"></i> Start Sync';
            enableAutoBtn.classList.replace('bg-red-500', 'bg-blue-600');
        }

        async function watchFolder() {
            if (!directoryHandle || isUploading) return;
            try {
                for await (const entry of directoryHandle.values()) {
                    if (entry.kind === 'file' && entry.name.match(/\.(xls|xlsx)$/)) {
                        if (!knownFiles.has(entry.name)) {
                            knownFiles.add(entry.name);
                            const file = await entry.getFile();
                            // Pass to trigger zone 1 logic
                            const dT = new DataTransfer();
                            dT.items.add(file);
                            document.getElementById('fileInput1').files = dT.files;
                            document.getElementById('fileInput1').dispatchEvent(new Event('change'));
                        }
                    }
                }
            } catch (e) { stopWatcher(); }
        }

        enableAutoBtn.addEventListener('click', startWatching);
        changeFolderBtn.addEventListener('click', async () => {
            stopWatcher();
            try {
                directoryHandle = await window.showDirectoryPicker();
                await storeHandle(directoryHandle);
                startWatching();
            } catch (e) {}
        });

        function showToast(msg, icon = "fa-bolt") {
            const toast = document.createElement('div');
            toast.className = "fixed bottom-5 right-5 bg-slate-800 text-white px-6 py-3 rounded-xl shadow-2xl text-sm font-medium z-[100] fade-in flex items-center gap-3 border-l-4 border-blue-400";
            toast.innerHTML = `<i class="fa-solid ${icon} text-blue-400 animate-pulse"></i> ${msg}`;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(10px)';
                toast.style.transition = 'all 0.5s ease';
                setTimeout(() => toast.remove(), 500);
            }, 4000);
        }

        setupUploadZone(1);
        setupUploadZone(2);
        setMode('manual');
    </script>
</body>
</html>